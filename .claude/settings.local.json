{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(snap list:*)",
      "Bash(apt list:*)",
      "Bash(curl -sL https://go.dev/dl/go1.24.1.linux-amd64.tar.gz -o /tmp/go.tar.gz)",
      "Bash(sudo tar:*)",
      "Bash(go *)",
      "Bash(/usr/local/go/bin/go version:*)",
      "Bash(export PATH=$PATH:/usr/local/go/bin:$HOME/go/bin)",
      "Bash(./agent/scripts/acp.package-search.sh core:*)",
      "Bash(./agent/scripts/acp.package-install.sh --list --repo https://github.com/prmichaelsen/acp-core-sdk-go.git)",
      "Bash(./agent/scripts/acp.package-install.sh --repo https://github.com/prmichaelsen/acp-core-sdk-go.git -y)",
      "Bash(export PATH=$PATH:/usr/local/go/bin)",
      "Bash(chmod:*)",
      "Bash(docker build:*)",
      "Bash(docker images:*)",
      "Bash(docker run:*)"
    ]
  }
}
